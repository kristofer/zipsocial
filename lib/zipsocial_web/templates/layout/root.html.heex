<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()}/>
    <title>ZipSocial</title>
    <style>
      /* Deliberately tiny inline stylesheet so you don't need a build step. */
      :root {
        --bg: #0D1B2A;
        --card: #152338;
        --text: #E6EDF3;
        --muted: #8b98a5;
        --teal: #00D4AA;
        --amber: #F0A500;
        --purple: #A855F7;
        --border: #243447;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }
      header {
        background: #09121c;
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
      }
      header .inner {
        max-width: 860px;
        margin: 0 auto;
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
      }
      header h1 { margin: 0; font-size: 20px; color: var(--teal); }
      header a {
        color: var(--text);
        text-decoration: none;
        font-size: 14px;
      }
      header a:hover { color: var(--teal); }
      main {
        max-width: 860px;
        margin: 32px auto;
        padding: 0 24px;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 16px;
      }
      .card h2, .card h3 { margin-top: 0; }
      .card a { color: var(--teal); }
      .muted { color: var(--muted); font-size: 13px; }
      .badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 12px;
        font-size: 12px;
        background: var(--border);
        color: var(--text);
      }
      .badge.java { background: var(--amber); color: #1a1a1a; }
      .badge.python { background: var(--purple); color: #fff; }
      form label {
        display: block;
        font-size: 13px;
        margin-top: 12px;
        color: var(--muted);
      }
      form input[type=text], form textarea, form select {
        width: 100%;
        padding: 10px;
        background: #0b1622;
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        font-size: 14px;
        font-family: inherit;
      }
      form textarea { min-height: 100px; resize: vertical; }
      button, .btn {
        background: var(--teal);
        color: #ffffff;
        border: none;
        padding: 10px 18px;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 16px;
        font-size: 14px;
        text-decoration: none;
        display: inline-block;
      }
      button:hover, .btn:hover { opacity: 0.9; }
      .flash {
        padding: 12px 16px;
        border-radius: 6px;
        margin-bottom: 16px;
      }
      .flash.info { background: rgba(0, 212, 170, 0.15); border: 1px solid var(--teal); }
      .flash.error { background: rgba(240, 80, 80, 0.15); border: 1px solid #f05050; }
      .errors { color: #ff8080; font-size: 13px; margin-top: 8px; }
      .errors ul { margin: 4px 0; padding-left: 20px; }
      .post-body { white-space: pre-wrap; }
      .comment {
        border-left: 2px solid var(--border);
        padding: 8px 12px;
        margin: 8px 0;
      }
      nav.filters { display: flex; gap: 8px; margin-bottom: 16px; }
      nav.filters a {
        padding: 6px 14px;
        border-radius: 16px;
        background: var(--card);
        border: 1px solid var(--border);
        font-size: 13px;
      }
      nav.filters a.active { background: var(--teal); color: #07131f; border-color: var(--teal); }
    </style>
  </head>
  <body>
    <header>
      <div class="inner">
        <h1>⚡ ZipSocial</h1>
        <a href="/">Feed</a>
        <a href="/users">Students</a>
        <%= if admin_logged_in?(@conn) do %>
          <a href="/posts/new">New post</a>
          <a href="/users/new">New student</a>
          <a href="/admin">Admin</a>
          <span class="muted" style="font-size: 13px;">· <%= current_admin_name(@conn) %> (admin)</span>
          <form method="post" action="/logout" style="display: inline;">
            <input type="hidden" name="_method" value="DELETE" />
            <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
            <button type="submit" style="background: none; color: var(--muted); border: none; cursor: pointer; font-size: 14px; padding: 0;">Log out</button>
          </form>
        <% else %>
          <%= if user_logged_in?(@conn) do %>
            <a href="/posts/new">New post</a>
            <span class="muted" style="font-size: 13px;">· <%= current_user_name(@conn) %></span>
            <form method="post" action="/logout" style="display: inline;">
              <input type="hidden" name="_method" value="DELETE" />
              <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
              <button type="submit" style="background: none; color: var(--muted); border: none; cursor: pointer; font-size: 14px; padding: 0;">Log out</button>
            </form>
          <% else %>
            <a href="/login">Log in</a>
          <% end %>
        <% end %>
      </div>
    </header>
    <main>
      <%= if info = get_flash(@conn, :info) do %>
        <div class="flash info"><%= info %></div>
      <% end %>
      <%= if error = get_flash(@conn, :error) do %>
        <div class="flash error"><%= error %></div>
      <% end %>
      <%= @inner_content %>
    </main>
  </body>
</html>
